# Compiled binaries - do not commit
SportsBettingFetcher.exe
*.obj
*.pdb
*.ilk
*.exp
*.lib

# Runtime DLLs - installed via vcpkg on target machine
libcurl.dll
zlib1.dll

# Logs - runtime generated
*.log
startup.log
fetcher.log

# Secrets - NEVER commit API keys
# main.cpp contains ODDS_API_KEY - see README for safe handling
secrets.txt
.env

# Visual Studio artifacts
.vs/
*.suo
*.user
ipch/
x64/
Debug/
Release/

# OS files
Thumbs.db
Desktop.ini
.DS_Store
